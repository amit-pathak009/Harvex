def collect_thetimemachine_output(domain, ttm_dir=None):
    """
    TheTimeMachine writes results to a 'content/<domain>/' directory.
    It may be relative to its own script dir OR the cwd. Check both.
    Also tries common variations of the domain folder name.
    """
    urls = set()

    # Build candidate base directories to search
    search_dirs = [os.getcwd()]
    if ttm_dir:
        search_dirs.append(ttm_dir)
    # Deduplicate
    search_dirs = list(dict.fromkeys(search_dirs))

    # Domain folder variations TheTimeMachine might use
    domain_variants = [domain, domain.replace(".", "_"), domain.split(".")[0]]

    patterns_tried = []
    for base in search_dirs:
        for variant in domain_variants:
            for pattern in [
                os.path.join(base, "content", variant, "*.txt"),
                os.path.join(base, "content", variant, "**", "*.txt"),
                os.path.join(base, variant, "*.txt"),
            ]:
                patterns_tried.append(pattern)
                for f in glob.glob(pattern, recursive=True):
                    try:
                        text = Path(f).read_text(errors='replace')
                        found = filter_urls_for_domain(text, domain)
                        urls.update(found)
                    except Exception:
                        pass

    if not QUIET:
        rprint(f"[dim]  [TTM] Scanned {len(patterns_tried)} path patterns → {len(urls)} URLs collected from files[/dim]")

    return urls

