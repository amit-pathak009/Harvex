# ── Raw terminal helpers — bypass Rich so \r truly overwrites the line ────────
def _twrite(text: str):
    """Write raw text to stdout and flush — no Rich markup, no trailing newline."""
    sys.stdout.write(text)
    sys.stdout.flush()

def _tclear():
    """Overwrite current line with spaces then return cursor to start."""
    sys.stdout.write("\r" + " " * 100 + "\r")
    sys.stdout.flush()

