                )
                tbl.add_row(display, status, "—" if found else install_cmd)
                if found:
                    installed += 1
            console.print(tbl)
            console.print(Panel(
                f"[bold green]Installed:[/bold green] [white]{installed}/{len(TOOLS)}[/white]  "
                f"[bold red]Missing:[/bold red] [white]{len(TOOLS) - installed}/{len(TOOLS)}[/white]\n"
                f"[dim]Run [bold cyan]harvex.py --auto-install[/bold cyan] for all install commands.[/dim]",
                title="[bold yellow]Dry Run Summary[/bold yellow]",
                border_style="yellow", padding=(0, 2)
            ))
        sys.exit(0)

    # ── Load domains ──────────────────────────────────────────────────────────
    domains = []
    if args.target:
        d = args.target.strip().lower()
        d = re.sub(r'^https?://', '', d).rstrip("/")
        domains.append(d)
    if args.list:
        try:
            for line in open(args.list):
                d = line.strip().lower()
                d = re.sub(r'^https?://', '', d).rstrip("/")
                if d:
                    domains.append(d)
        except Exception as e:
            rprint(f"[bold red]Error reading list: {e}[/bold red]")
            sys.exit(1)
    domains = list(dict.fromkeys(domains))   # deduplicate, preserve order

    out_dir = Path(args.output_dir)
    out_dir.mkdir(exist_ok=True)
    (out_dir / "raw").mkdir(exist_ok=True)

    skipped_tools    = [x.strip().lower() for x in args.skip.split(",")] if args.skip else []
    all_urls         = set()
    tool_counts      = defaultdict(set)
    discovered_count = 0
    start_time       = datetime.now()
    TOR              = TOR_SOCKS5

    if not QUIET and HAS_RICH:
        console.print(Panel(
            f"[bold cyan]Targets   :[/bold cyan] [white]{', '.join(domains[:3])}{'...' if len(domains) > 3 else ''}[/white]\n"
            f"[bold cyan]Count     :[/bold cyan] [white]{len(domains)} domain(s)[/white]\n"
            f"[bold cyan]Tor / PC  :[/bold cyan] [white]{'✅ Enabled' if use_pc else '❌ Disabled'}[/white]\n"
            f"[bold cyan]Skip      :[/bold cyan] [white]{', '.join(skipped_tools) or 'none'}[/white]\n"
            f"[bold cyan]Quiet     :[/bold cyan] [white]{'✅ Yes' if QUIET else '❌ No'}[/white]",
            title="[bold magenta]⚙  Configuration[/bold magenta]",
            border_style="magenta", padding=(0, 2)
        ))

    # ── Central URL collector ─────────────────────────────────────────────────
    _lock = threading.Lock()

    def add_url(tool_name, url, local_set):
        nonlocal discovered_count
        with _lock:
            if url not in local_set:
                local_set.add(url)
                all_urls.add(url)
                tool_counts[tool_name].add(url)
                discovered_count += 1

    def is_skipped(name):
        return name.lower() in skipped_tools

    def check(binary):
        return shutil.which(binary) is not None

    def save_raw(name, content, tag=""):
        if args.save_raw and content:
            fname = f"{name}_{tag}.txt" if tag else f"{name}.txt"
            (out_dir / "raw" / fname).write_text(content)

    # ─────────────────────────────────────────────────────────────────────────
    # TheTimeMachine dedicated runner
    # TheTimeMachine writes results to disk, not stdout — needs special handling
    # ─────────────────────────────────────────────────────────────────────────
    def _run_thetimemachine(domain, ttm_dir, ttm_script, local_set, use_proxychains):
        name = "TheTimeMachine"

        # Tor rotate + get circuit info first
        new_ip   = None
        entry_fp = None
        exit_fp  = None
        if use_proxychains:
            new_ip             = rotate_tor_ip()
            entry_fp, exit_fp  = get_tor_circuit_info()
            if new_ip is None:
                new_ip = get_tor_exit_ip()

        # Build display strings for the panel
        if use_proxychains:
            ip_disp  = new_ip or "unknown"
            en_disp  = entry_fp[:20] if entry_fp else "—"
            ex_disp  = exit_fp[:20]  if exit_fp  else "—"
            tor_line = f"\n  🧅 Exit IP: {ip_disp}  Entry: {en_disp}  Exit:  {ex_disp}"
        else:
            tor_line = ""

        if not QUIET and HAS_RICH:
            console.print(Panel(
                f"[bold yellow]⚡ {name}[/bold yellow]{tor_line}",
                border_style="yellow", padding=(0, 2)
            ))

        # Build command — cd into TTM dir so its relative imports work
        base_cmd = f"cd {ttm_dir} && python3 {ttm_script} {domain} --fetch"
        if use_proxychains and shutil.which("proxychains4"):
            safe = base_cmd.replace("'", "'\\''")
            cmd  = f"proxychains4 -f {PROXYCHAINS_CONF} -q bash -c '{safe}'"
        else:
            cmd = base_cmd

        start_ts   = time.time()
        _ttm_done  = threading.Event()

        def _ttm_ticker():
            while not _ttm_done.wait(timeout=1.0):
                if not QUIET:
                    secs = int(time.time() - start_ts)
                    m, s = divmod(secs, 60)
                    elapsed = f"{m}m {s:02d}s" if m else f"{s}s"
                    _twrite(f"\r  ⚡ {name}  running...  [{elapsed}]  🧅 {new_ip or ''}  ")

        ttm_ticker = threading.Thread(target=_ttm_ticker, daemon=True)

        try:
            proc = subprocess.Popen(
                cmd, shell=True,
                stdout=subprocess.PIPE, stderr=subprocess.PIPE,
                text=True, errors='replace'
            )

            ttm_ticker.start()

            # Drain stdout so the process doesn't block on a full pipe buffer
            for _ in proc.stdout:
                pass

            proc.wait()
            stderr_out = proc.stderr.read()

        except KeyboardInterrupt:
            _ttm_done.set()
            try: proc.terminate()
            except Exception: pass
            raise
        except Exception as e:
            _ttm_done.set()
            _tclear()
            rprint(f"[bold red]  [-] {name} error: {e}[/bold red]")
            return
        finally:
            _ttm_done.set()
            ttm_ticker.join(timeout=1.5)

        # ── Now collect the output files TTM wrote to disk ────────────────────
        _tclear()
        collected = collect_thetimemachine_output(domain, ttm_dir=ttm_dir)

        secs = int(time.time() - start_ts)
        m, s = divmod(secs, 60)
        elapsed_str = f"{m}m {s:02d}s" if m else f"{s}s"

        for url in collected:
            add_url(name, url, local_set)

        url_count = len(collected)
        icon  = "✓" if url_count > 0 else "○"
        color = "bold green" if url_count > 0 else "dim yellow"
        if not QUIET and HAS_RICH:
            console.print(
                f"  [{color}]{icon}[/{color}] [cyan]{name}[/cyan]  "
                f"[bold white]+{url_count:,} URLs[/bold white]  "
                f"[dim]elapsed: {elapsed_str}[/dim]"
            )
            if url_count == 0:
                # Show stderr snippet to help diagnose failures
                if stderr_out and stderr_out.strip():
                    snippet = stderr_out.strip().splitlines()[-3:]
                    rprint(f"[dim red]  [TTM stderr] {' | '.join(snippet)}[/dim red]")
                rprint(f"[dim yellow]  ℹ  {name}: 0 URLs — check THETIMEMACHINE_PATH and that the tool ran successfully[/dim yellow]")
        elif not QUIET:
            print(f"  {icon} {name}: +{url_count}  elapsed: {elapsed_str}")

    # ─────────────────────────────────────────────────────────────────────────
    # Harvest function
    # ─────────────────────────────────────────────────────────────────────────
    def harvest(target_domains):
        local   = set()
        is_list = len(target_domains) > 1
        list_file = args.list if is_list else None

        def on_url(tool_name):
            def _cb(url):
                add_url(tool_name, url, local)
            return _cb

        def run(name, cmd, ttype="go", domain_filter=None):
            if is_skipped(name):
                return
            dlist = domain_filter or target_domains
            count, _ = run_tool_live(
                name, cmd, dlist,
                use_proxychains=use_pc,
                tool_type=ttype,
                on_url=on_url(name)
            )
            if count == 0 and not QUIET:
                rprint(f"[dim yellow]  ℹ  {name}: 0 URLs matched domain scope[/dim yellow]")

        # ── TheTimeMachine (Python) ───────────────────────────────────────────
        # TheTimeMachine writes results to content/<domain>/*.txt — it does NOT
        # print URLs to stdout. We must run it, wait for completion, then read
        # the output files. A dedicated runner is used instead of run_tool_live.
        if not is_skipped("thetimemachine"):
            ttm_path = Path(THETIMEMACHINE_PATH)
            if ttm_path.exists():
                ttm_dir    = str(ttm_path.parent)
                ttm_script = ttm_path.name
                for d in target_domains:
                    _run_thetimemachine(d, ttm_dir, ttm_script, local, use_pc)
            elif not QUIET:
                rprint(
                    f"[bold yellow]  [SKIP] TheTimeMachine — not found at:[/bold yellow] "
                    f"[dim]{THETIMEMACHINE_PATH}[/dim]\n"
                    f"[dim]  Edit THETIMEMACHINE_PATH at the top of harvex.py[/dim]"
                )

        # ── waymore (Python — proxychains4 works) ────────────────────────────
        if not is_skipped("waymore") and check("waymore"):
            if is_list:
                run("waymore", f"waymore -i {list_file} -mode U --stream", ttype="python")
            else:
                run("waymore", f"waymore -i {target_domains[0]} -mode U --stream", ttype="python")
        elif not is_skipped("waymore"):
            rprint("[bold yellow]  [SKIP] waymore — not found[/bold yellow]")

        # ── gau (Go — native --proxy socks5://) ──────────────────────────────
        if not is_skipped("gau") and check("gau"):
            pf = f" --proxy {TOR}" if use_pc else ""
            bl = "--blacklist png,jpg,jpeg,gif,svg,css,woff,ttf,woff2,ico"
            if is_list:
                run("gau",
                    f"cat {list_file} | xargs -I{{}} gau --subs{pf} {bl} {{}}",
                    ttype="go")
            else:
                run("gau",
                    f"gau --subs{pf} {bl} {target_domains[0]}",
                    ttype="go")
        elif not is_skipped("gau"):
            rprint("[bold yellow]  [SKIP] gau — not found[/bold yellow]")

        # ── waybackurls (Go — no proxy support, run direct) ──────────────────
        if not is_skipped("waybackurls") and check("waybackurls"):
            if is_list:
                run("waybackurls", f"cat {list_file} | waybackurls", ttype="direct")
            else:
                run("waybackurls", f"echo {target_domains[0]} | waybackurls", ttype="direct")
        elif not is_skipped("waybackurls"):
            rprint("[bold yellow]  [SKIP] waybackurls — not found[/bold yellow]")

        # ── urlfinder (Go — -proxy) ───────────────────────────────────────────
        if not is_skipped("urlfinder") and check("urlfinder"):
            pf = f" -proxy {TOR}" if use_pc else ""
            if is_list:
                run("urlfinder", f"urlfinder -d {list_file} -silent -all{pf}", ttype="go")
            else:
                run("urlfinder",
                    f"urlfinder -d {target_domains[0]} -silent -all{pf}", ttype="go")
        elif not is_skipped("urlfinder"):
            rprint("[bold yellow]  [SKIP] urlfinder — not found[/bold yellow]")

        # ── katana (Go — -proxy) — NOTE: -jc removed per user request ─────────
        if not is_skipped("katana") and check("katana"):
            pf = f" -proxy {TOR}" if use_pc else ""
            if is_list:
                run("katana",
                    f"katana -list {list_file} -d 999999 -jsl -kf all -aff -fx -pc -silent{pf}",
                    ttype="go")
            else:
                run("katana",
                    f"katana -u {target_domains[0]} -d 999999 -jsl -kf all -aff -fx -pc -silent{pf}",
                    ttype="go")
        elif not is_skipped("katana"):
            rprint("[bold yellow]  [SKIP] katana — not found[/bold yellow]")

        # ── hakrawler (no proxy — confirmed working flags) ────────────────────
        if not is_skipped("hakrawler") and check("hakrawler"):
            if is_list:
                run("hakrawler",
                    f"cat {list_file} | sed 's|^|https://|' | hakrawler -subs -d 999999 --insecure",
                    ttype="direct")
            else:
                run("hakrawler",
                    f'echo "https://{target_domains[0]}" | hakrawler -subs -d 999999 --insecure',
                    ttype="direct")
        elif not is_skipped("hakrawler"):
            rprint("[bold yellow]  [SKIP] hakrawler — not found[/bold yellow]")

        # ── cariddi (Go — -proxy) — no https:// prefix needed ─────────────────
        if not is_skipped("cariddi") and check("cariddi"):
            pf = f" -proxy {TOR}" if use_pc else ""
            if is_list:
                run("cariddi",
                    f"cat {list_file} | cariddi -intensive -plain{pf}",
                    ttype="go")
            else:
                run("cariddi",
                    f"echo {target_domains[0]} | cariddi -intensive -plain{pf}",
                    ttype="go")
        elif not is_skipped("cariddi"):
            rprint("[bold yellow]  [SKIP] cariddi — not found[/bold yellow]")

        # ── gospider (Go — -p proxy) ──────────────────────────────────────────
        if not is_skipped("gospider") and check("gospider"):
            pf = f" -p {TOR}" if use_pc else ""
            if is_list:
                run("gospider",
                    f"gospider -S {list_file} -d 999999 -a -r -K 5 -w -u random{pf}",
                    ttype="go")
            else:
                run("gospider",
                    f"gospider -s https://{target_domains[0]} -d 999999 -a -r -K 5 -w -u random{pf}",
                    ttype="go")
        elif not is_skipped("gospider"):
            rprint("[bold yellow]  [SKIP] gospider — not found[/bold yellow]")

        # ── URLFinder (Go — -x proxy) — no https:// prefix needed ────────────
        if not is_skipped("urlfinder_pingc0y") and check("URLFinder"):
            pf = f" -x {TOR}" if use_pc else ""
            if is_list:
                run("URLFinder (pingc0y)",
                    f"URLFinder -f {list_file} -m 2 -z 3 -s all -max 99999999999{pf}",
                    ttype="go")
            else:
                run("URLFinder (pingc0y)",
                    f"URLFinder -u {target_domains[0]} -m 2 -z 3 -s all -max 99999999999{pf}",
                    ttype="go")
        elif not is_skipped("urlfinder_pingc0y"):
            rprint("[bold yellow]  [SKIP] URLFinder (pingc0y) — not found[/bold yellow]")

        return local

    # ── Run harvest ───────────────────────────────────────────────────────────
    if not QUIET:
        console.rule("[bold cyan]🚀  Harvest Starting[/bold cyan]", style="cyan")

    harvest(domains)

    # ── Subdomain expansion ───────────────────────────────────────────────────
    if args.include_subs and check("subfinder"):
        if not QUIET:
            console.rule("[bold yellow]🔍  Subdomain Expansion[/bold yellow]", style="yellow")
        for d in domains:
            pf = f" -proxy {TOR}" if use_pc else ""
            out = _exec(f"subfinder -d {d} -silent{pf}")
            save_raw("subfinder", out, d)
            for url in filter_urls_for_domain(out, d):
                add_url("subfinder", url, all_urls)

    total_before_uro = len(all_urls)
    urls_list = sorted(all_urls)

    # ── URO dedup ─────────────────────────────────────────────────────────────
    if not args.no_uro and check("uro"):
        if not QUIET:
            console.rule("[bold yellow]🧹  URO Deduplication[/bold yellow]", style="yellow")
        with tempfile.NamedTemporaryFile(mode="w+", suffix=".txt", delete=False) as f:
            f.write("\n".join(urls_list))
            tmp = f.name
        out = _exec(f"uro -i {tmp}")
        os.unlink(tmp)
        deduped = {l.strip() for l in out.splitlines() if l.strip().startswith("http")}
        if deduped:
            urls_list = sorted(deduped)
        if not QUIET:
            rprint(f"[bold green]  ✓ After uro: [cyan bold]{len(urls_list):,}[/cyan bold] URLs[/bold green]")
    elif not args.no_uro and not QUIET:
        rprint("[bold yellow]  [!] uro not found — skipping dedup[/bold yellow]")

    # ── Params filter ─────────────────────────────────────────────────────────
    if args.params_only:
        urls_list = [u for u in urls_list if '?' in u]
        if not QUIET:
            rprint(f"[bold cyan]  ✓ URLs with params: {len(urls_list):,}[/bold cyan]")

    # ── Live filter ───────────────────────────────────────────────────────────
    if args.live and check("httpx"):
        if not QUIET:
            console.rule("[bold yellow]🔗  Live URL Filtering[/bold yellow]", style="yellow")
        with tempfile.NamedTemporaryFile(mode="w+", suffix=".txt", delete=False) as f:
            f.write("\n".join(urls_list))
            tmp = f.name
        pf  = f" -proxy {TOR}" if use_pc else (f" -proxy {args.proxy}" if args.proxy else "")
        out = _exec(f"httpx -l {tmp} -silent -mc 200,301,302,307,308{pf}")
        os.unlink(tmp)
        live = {l.strip() for l in out.splitlines() if l.strip().startswith("http")}
        if live:
            urls_list = sorted(live)
        if not QUIET:
            rprint(f"[bold green]  ✓ Live URLs: {len(urls_list):,}[/bold green]")
    elif args.live and not QUIET:
        rprint("[bold yellow]  [!] httpx not found — skipping live filter[/bold yellow]")

    # ── Save output ───────────────────────────────────────────────────────────
    ts       = datetime.now().strftime("%Y%m%d_%H%M%S")
    txt_file = out_dir / (args.output or f"harvested_urls_{ts}.txt")
    txt_file.write_text("\n".join(urls_list) + "\n")

    # ── Final Tor status ──────────────────────────────────────────────────────
    if use_pc and not QUIET:
        print_tor_panel("Final — Last Exit Node")

    # ── Summary ───────────────────────────────────────────────────────────────
    if not QUIET:
        print_final_summary(tool_counts, total_before_uro, len(urls_list),
                            txt_file, start_time, use_pc)
    else:
        print(str(txt_file))

    if _tor_controller:
        try:
            _tor_controller.close()
        except Exception:
            pass


