def rotate_tor_ip():
    """Send NEWNYM with live countdown (single overwriting line). Returns new exit IP or None."""
    global _tor_controller
    if _tor_controller is None:
        return None
    try:
        from stem import Signal
        with _tor_lock:
            wait = _tor_controller.get_newnym_wait()
            if wait > 0:
                if not QUIET:
                    for remaining in range(int(wait), 0, -1):
                        _twrite(f"\r  🔄 New Tor circuit in {remaining}s  ")
                        time.sleep(1)
                    _tclear()
                else:
                    time.sleep(wait)
            _tor_controller.signal(Signal.NEWNYM)
            time.sleep(1)
        ip = get_tor_exit_ip()
        return ip
    except Exception as e:
        if not QUIET:
            rprint(f"[bold yellow][!] NEWNYM failed: {e}[/bold yellow]")
        return None

def get_tor_exit_ip(timeout=12):
    """Fetch exit IP via proxychains4 curl.
    Uses raw sys.stdout writes so the spinner truly overwrites a single line.
    """
    result = [None]
    done   = threading.Event()

    def _fetch():
        try:
            r = subprocess.run(
                "proxychains4 -q curl -s --max-time 8 https://api.ipify.org",
                shell=True, capture_output=True, text=True, timeout=10
            )
            ip = r.stdout.strip()
            if re.match(r'^\d+\.\d+\.\d+\.\d+$', ip):
                result[0] = ip
        except Exception:
            pass
        finally:
            done.set()

    t = threading.Thread(target=_fetch, daemon=True)
    t.start()

    spin_chars = ["⠋", "⠙", "⠹", "⠸", "⠼", "⠴", "⠦", "⠧", "⠇", "⠏"]
    waited = 0.0
    idx    = 0
    while not done.wait(timeout=0.12) and waited < timeout:
        if not QUIET:
            _twrite(f"\r  🧅 fetching exit IP {spin_chars[idx % len(spin_chars)]}  ")
        waited += 0.12
        idx    += 1

    # Erase the spinner line completely before caller prints anything
    if not QUIET:
        _tclear()

    done.set()
    t.join(timeout=0.3)
    return result[0]

def get_tor_circuit_info():
    """Return (entry_fingerprint, exit_fingerprint) of the best BUILT circuit.

    Tries multiple strategies to find a usable circuit because stem's
    circuit list ordering and status values can vary by version:
      1. Status string "BUILT" with 3-hop path (ideal)
      2. Status string "BUILT" with any path >= 2 hops
      3. Any circuit with a path >= 2 hops as fallback
    """
    if _tor_controller is None:
        return None, None
    try:
        circuits = list(_tor_controller.get_circuits())
        if not circuits:
            return None, None

        # Strategy 1 & 2: prefer explicitly BUILT circuits
        best = None
        for circ in circuits:
            status_str = str(circ.status).upper()
            path = circ.path or []
            if status_str == "BUILT" and len(path) >= 2:
                if best is None or len(path) > len(best.path):
                    best = circ

        # Strategy 3: any circuit with a usable path
        if best is None:
            for circ in circuits:
                path = circ.path or []
                if len(path) >= 2:
                    best = circ
                    break

        if best and best.path and len(best.path) >= 2:
            entry = best.path[0][0]   # guard / entry fingerprint
            exit_ = best.path[-1][0]  # exit node fingerprint
            return entry, exit_

    except Exception as e:
        if not QUIET:
            rprint(f"[dim yellow]  [tor] circuit info error: {e}[/dim yellow]")
    return None, None

