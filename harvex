    # ── Tor / proxychains init ────────────────────────────────────────────────
    use_pc = not args.no_proxychains

    if use_pc:
        if not shutil.which("proxychains4"):
            rprint("[bold red][!] proxychains4 not found: sudo apt install proxychains4[/bold red]")
