def make_domain_regex(domain):
    if domain not in DOMAIN_REGEX_CACHE:
        escaped = re.escape(domain)
        pattern = re.compile(
            r'https?://(?:[a-zA-Z0-9_\-]+\.)*' + escaped + r'(?:[/?#][^\s"\'<>]*)?',
            re.IGNORECASE
        )
        DOMAIN_REGEX_CACHE[domain] = pattern
    return DOMAIN_REGEX_CACHE[domain]

def filter_urls_for_domain(text, domain):
    pattern = make_domain_regex(domain)
    urls = set()
    for url in pattern.findall(text):
        url = url.rstrip('.,;)')
        urls.add(url)
    return urls

def filter_urls_for_domains(text, domain_list):
    urls = set()
    for domain in domain_list:
        urls.update(filter_urls_for_domain(text, domain))
    return urls

