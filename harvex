            "gau":           ("gau",          "go install github.com/lc/gau/v2/cmd/gau@latest"),
            "waybackurls":   ("waybackurls",  "go install github.com/tomnomnom/waybackurls@latest"),
            "urlfinder":     ("urlfinder",    "go install github.com/projectdiscovery/urlfinder/cmd/urlfinder@latest"),
            "katana":        ("katana",       "go install github.com/projectdiscovery/katana/cmd/katana@latest"),
            "hakrawler":     ("hakrawler",    "go install github.com/hakluke/hakrawler@latest"),
            "cariddi":       ("cariddi",      "go install github.com/edoardottt/cariddi/cmd/cariddi@latest"),
            "gospider":      ("gospider",     "go install github.com/jaeles-project/gospider@latest"),
            "URLFinder":     ("URLFinder",    "https://github.com/pingc0y/URLFinder (manual build)"),
            "uro":           ("uro",          "pip3 install uro --break-system-packages"),
            "httpx":         ("httpx",        "go install github.com/projectdiscovery/httpx/cmd/httpx@latest"),
            "subfinder":     ("subfinder",    "go install github.com/projectdiscovery/subfinder/v2/cmd/subfinder@latest"),
            "proxychains4":  ("proxychains4", "sudo apt install proxychains4 -y"),
            "tor":           ("tor",          "sudo apt install tor -y"),
            "stem (python)": ("python3",      "pip3 install stem --break-system-packages"),
        }
        console.rule("[bold cyan]🔍  Dry Run — Tool Check[/bold cyan]", style="cyan")
        if HAS_RICH:
            tbl = Table(
                box=box.DOUBLE_EDGE, border_style="cyan",
                header_style="bold magenta", show_lines=True,
                title="[bold cyan]Installed Tools[/bold cyan]"
            )
            tbl.add_column("🔧  Tool",   style="cyan", min_width=20)
            tbl.add_column("✅  Status",              min_width=16)
            tbl.add_column("📦  Install", style="dim", min_width=30)
            installed = 0
            for display, (binary, install_cmd) in TOOLS.items():
                found = shutil.which(binary) is not None
                if display == "stem (python)":
                    try:
                        import stem; found = True
                    except ImportError:
                        found = False
                if display == "tor":
                    import socket
                    try:
                        s = socket.create_connection(("127.0.0.1", 9050), timeout=1)
                        s.close()
                        found = True
                    except Exception:
                        found = shutil.which("tor") is not None
                status = (
                    "[bold green]✅ Installed[/bold green]"
                    if found else
