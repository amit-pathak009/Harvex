def run_tool_live(name, cmd, domain_list, use_proxychains=True,
                  tool_type="go", on_url=None):
    """
    Execute a tool and stream its output line by line in real time.
    Shows a single overwriting status line:
        ⚡ [tool]  collecting: N urls  [Xs]  🧅 IP

    tool_type:
      "python" — wrap with proxychains4 bash -c
      "go"     — proxy flag already in cmd
      "direct" — no proxy, run as-is
    """
    global QUIET

    # ── Tor rotation before tool starts ──────────────────────────────────────
    new_ip   = None
    entry_fp = None
    exit_fp  = None

    if use_proxychains:
        new_ip             = rotate_tor_ip()          # single spinner, then clears line
        entry_fp, exit_fp  = get_tor_circuit_info()

    # ── Resolve IP in background if still None ────────────────────────────────
    if use_proxychains and new_ip is None:
        new_ip = get_tor_exit_ip()                    # one more attempt, spinner clears itself

    # ── Build tor display strings ─────────────────────────────────────────────
    if use_proxychains:
        ip_disp  = f"[bold green]{new_ip}[/bold green]"   if new_ip   else "[dim yellow]unknown[/dim yellow]"
        en_disp  = f"[dim]{entry_fp[:20]}[/dim]"          if entry_fp else "[dim yellow]—[/dim yellow]"
        ex_disp  = f"[dim]{exit_fp[:20]}[/dim]"           if exit_fp  else "[dim yellow]—[/dim yellow]"
        tor_line = (
            f"\n  [cyan]🧅 Exit IP:[/cyan] {ip_disp}  "
            f"[cyan]Entry:[/cyan] {en_disp}  "
            f"[cyan]Exit:[/cyan]  {ex_disp}"
        )
    else:
        tor_line = ""

    # ── Print tool header ─────────────────────────────────────────────────────
    if not QUIET and HAS_RICH:
        console.print(Panel(
            f"[bold yellow]⚡ {name}[/bold yellow]{tor_line}",
            border_style="yellow", padding=(0, 2)
        ))
    elif not QUIET:
        rprint(f"\n[*] {name}  Tor: {new_ip or 'unknown'}")

    # ── Build final command ───────────────────────────────────────────────────
    if use_proxychains and tool_type == "python" and shutil.which("proxychains4"):
        safe = cmd.replace("'", "'\\''")
        cmd  = f"proxychains4 -f {PROXYCHAINS_CONF} -q bash -c '{safe}'"

    # ── Stream output in real time ────────────────────────────────────────────
    url_count  = 0
    start_ts   = time.time()
    _proc_done = threading.Event()

    def _status_line_raw():
        """Plain text status for raw sys.stdout (no Rich markup)."""
        tor_bit = f"  🧅 {new_ip}" if (use_proxychains and new_ip) else ""
        secs = int(time.time() - start_ts)
        m, s = divmod(secs, 60)
        elapsed = f"{m}m {s:02d}s" if m else f"{s}s"
        return f"\r  ⚡ {name}  collecting: {url_count:,} urls  [{elapsed}]{tor_bit}  "

    def _ticker():
        """Background thread: rewrite status line every second so timer never freezes."""
        while not _proc_done.wait(timeout=1.0):
            if not QUIET:
                _twrite(_status_line_raw())

    ticker_thread = threading.Thread(target=_ticker, daemon=True)

    try:
        proc = subprocess.Popen(
            cmd, shell=True,
            stdout=subprocess.PIPE, stderr=subprocess.PIPE,
            text=True, errors='replace'
        )

        ticker_thread.start()

        for line in proc.stdout:
            line = line.rstrip()
            if not line:
                continue
            line_urls = filter_urls_for_domains(line, domain_list)
            for url in line_urls:
                url_count += 1
                if on_url:
                    on_url(url)

        proc.wait()
        stderr_out = proc.stderr.read()

    except KeyboardInterrupt:
        _proc_done.set()
        try: proc.terminate()
        except Exception: pass
        raise
    except Exception as e:
        _proc_done.set()
        if not QUIET:
            rprint(f"[bold red]  [-] {name} error: {e}[/bold red]")
        return 0, ""
    finally:
        _proc_done.set()
        ticker_thread.join(timeout=1.5)

    # ── Final summary line ────────────────────────────────────────────────────
    if not QUIET:
        _tclear()
        secs = int(time.time() - start_ts)
        m, s = divmod(secs, 60)
        elapsed_str = f"{m}m {s:02d}s" if m else f"{s}s"
        icon = "✓" if url_count > 0 else "○"
        if HAS_RICH:
            color = "bold green" if url_count > 0 else "dim yellow"
            console.print(
                f"  [{color}]{icon}[/{color}] [cyan]{name}[/cyan]  "
                f"[bold white]+{url_count:,} URLs[/bold white]  "
                f"[dim]elapsed: {elapsed_str}[/dim]"
            )
        else:
            rprint(f"  {icon} {name}: +{url_count}  elapsed: {elapsed_str}")

    return url_count, stderr_out

# ──────────────────────────────────────────────────────────────────────────────
# _exec — for non-streaming tools (uro, httpx, subfinder)
# ──────────────────────────────────────────────────────────────────────────────

def _exec(cmd, extra_env=None):
    env = None
    if extra_env:
        env = copy.copy(os.environ)
        env.update(extra_env)
    try:
        r = subprocess.run(cmd, shell=True, capture_output=True,
                           text=True, errors='replace', env=env)
        return r.stdout + r.stderr
    except Exception as e:
        rprint(f"[bold red]  [-] Error: {e}[/bold red]")
        return ""

